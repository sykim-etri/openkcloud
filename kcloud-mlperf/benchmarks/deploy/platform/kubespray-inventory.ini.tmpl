# consumes: CONTROL_PLANE_IP SSH_PORT_CP NODE_ENTRIES_ALL
#           NODE_ENTRIES_ALL  (lines for the [all] section, assembled by stages.sh before envsubst;
#                              format per node: "nodeN ansible_host=<IP> ansible_port=<PORT> ip=<IP> etcd_member_name=etcd1"
#                              First IP = control-plane/etcd; remaining IPs = kube_node workers.
#                              stages.sh helper _inventory_all_entries() emits these lines.)
#           KUBE_CONTROL_PLANE_HOSTS  (single host entry: "node1")
#           ETCD_HOSTS                (single host entry: "node1")
#           KUBE_NODE_HOSTS           (one line per worker node: "node2\nnode3\n...")
#
# Rendered by: stages.sh stage_provision() via envsubst → deploy/render/inventory/inventory.ini
# Consumed by: kubespray cluster.yml (ansible-playbook -i <render>/inventory.ini ...)
# Structure must stay compatible with kubespray/inventory/sample/inventory.ini.

# ## Configure 'ip' variable to bind kubernetes services on a
# ## different ip than the default iface
# ## We should set etcd_member_name for etcd cluster. The node that is not a etcd member do not need to set the value, or can set the empty string value.
[all]
${NODE_ENTRIES_ALL}

# ## configure a bastion host if your nodes are not directly reachable
# [bastion]
# bastion ansible_host=x.x.x.x ansible_user=some_user

[kube_control_plane]
${KUBE_CONTROL_PLANE_HOSTS}

[etcd]
${ETCD_HOSTS}

[kube_node]
${KUBE_NODE_HOSTS}

[calico_rr]

[k8s_cluster:children]
kube_control_plane
kube_node
calico_rr
