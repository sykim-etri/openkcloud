# consumes: CONTROL_PLANE_IP APP_NAMESPACE BENCH_NAMESPACE SSH_PORT_CP SSH_PORT_NPU MANAGED_BY PART_OF
#           WORKER_ENTRIES  (multi-line YAML block assembled by stages.sh before envsubst;
#                            each worker line is produced by the helper
#                            _cluster_yaml_worker_entry() in stages.sh:
#                              - name: nodeN
#                                role: worker
#                                accelerator: { type: cpu, vendor: intel, count: 0 }
#                                ssh: { host: <IP>, port: <SSH_PORT_CP|SSH_PORT_NPU> }
#                            SSH_PORT_CP (default 122) for GPU/CPU workers,
#                            SSH_PORT_NPU (default 22) for NPU workers.
#                            Indented 2 spaces to align under the "workers:" key.
#                            WORKER_ENTRIES is whitelisted in STAGES_ENVSUBST_VARS so it
#                            is always substituted — no literal ${WORKER_ENTRIES} can ship.)
#
# Rendered by: stages.sh stage_webapp() via envsubst -> deploy/render/<run>/app-chart/config/cluster.yaml
# Consumed by: app-chart cluster-config.yaml ConfigMap (backend reads it as device registry)
# Must stay structurally compatible with app-chart/config/cluster.yaml.
#
# SECURITY: This file is mounted into an in-cluster ConfigMap. It MUST NOT carry any
# SSH/sudo credential, password, or password env-var name. Node SSH/sudo credentials
# live ONLY in the operator-side kubespray/SSHPASS runtime path, never here.

# Generated by kcloud-tool
# app.kubernetes.io/managed-by: ${MANAGED_BY}
# app.kubernetes.io/part-of: ${PART_OF}

cluster_name: kcloud-stack
kubeconfig: ~/.kube/config

ssh:
  default_port: ${SSH_PORT_CP}
  npu_port: ${SSH_PORT_NPU}

control_plane:
  - name: node1
    role: master
    accelerator: { type: cpu, vendor: intel, count: 0 }
    ssh: { host: ${CONTROL_PLANE_IP}, port: ${SSH_PORT_CP} }

workers:
${WORKER_ENTRIES}

namespaces:
  app: ${APP_NAMESPACE}
  benchmarks: ${BENCH_NAMESPACE}
  monitoring: monitoring
  loki: loki
