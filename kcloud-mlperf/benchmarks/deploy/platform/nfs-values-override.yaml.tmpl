# consumes: NFS_SERVER NFS_PATH MANAGED_BY PART_OF
# Helm values override for nfs-subdir-external-provisioner.
# Rendered by the orchestrator via envsubst; passed as -f <render> to helm upgrade --install.
# Keys and structure must stay aligned with nfs-subdir-external-provisioner-4.0.18/values.yaml.

nfs:
  server: ${NFS_SERVER}
  path: ${NFS_PATH}

storageClass:
  create: true
  name: nfs-client
  defaultClass: true
  allowVolumeExpansion: true
  reclaimPolicy: Delete
  archiveOnDelete: true
  # ReadWriteMany — required for multi-pod RWX access (benchmark results PVC)
  accessModes: ReadWriteMany
  volumeBindingMode: Immediate
  annotations: {}

labels:
  app.kubernetes.io/managed-by: ${MANAGED_BY}
  app.kubernetes.io/part-of: ${PART_OF}
