# consumes: ACCESS_IP BACKEND_NODEPORT APP_NAMESPACE MANAGED_BY PART_OF
# Minimal Helm values override for app-chart.
# Rendered by the orchestrator via envsubst; passed as -f <override> after the base values.yaml.
# Keys must stay aligned with app-chart/values.yaml (global.namespace,
# components.etriLLMFrontend, components.etriLLMBackend).
#
# global.namespace drives the namespace of EVERY rendered object in the app-chart
# (the chart derives object .metadata.namespace from .Values.global.namespace, NOT
# from the Helm release namespace). Setting it to ${APP_NAMESPACE} is what actually
# moves the app when --app-namespace is supplied.
#
# Frontend VITE base URL: the orchestrator patches ONLY the VITE__APP_API_BASE_URL
# line in the chart-copy's frontend secret.yaml (preserving every other key, incl.
# the Helm-templated HF_TOKEN). It does NOT rely on a --set-string for the URL.
# Rendered VITE URL value: http://${ACCESS_IP}:${BACKEND_NODEPORT}/api

global:
  namespace: ${APP_NAMESPACE}

# Labels injected into every chart resource via the labels helper in _helpers.tpl.
# These satisfy the kcloud-tool managed-by / part-of ownership contract.
commonLabels:
  app.kubernetes.io/managed-by: ${MANAGED_BY}
  app.kubernetes.io/part-of: ${PART_OF}
