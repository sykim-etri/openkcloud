# ============================================================
# deploy.env.example: NPU Operator 배포 환경 변수 예시
# 상세: 이 파일을 deploy.env 로 복사 후 값을 채워 install.sh 에서 사용합니다.
#       deploy.env 는 .gitignore 에 포함되어 있으므로 커밋되지 않습니다.
# 사용법:
#   cp deploy.env.example deploy.env
#   vi deploy.env        # REGISTRY 를 반드시 설정하세요
#   bash install.sh
# 생성일: 2026-06-02
# ============================================================

# [필수] 클러스터에서 pull 가능한 사설 이미지 레지스트리 주소 (host:port)
# operator/detector/device-plugin/driver 이미지의 레지스트리 prefix 로 주입됩니다.
# nvcr.io / ghcr.io 같은 public 이미지에는 적용되지 않습니다.
# 예: REGISTRY=<your-registry>
REGISTRY=

# [선택] Helm 릴리스 이름 (기본값: npu-operator)
RELEASE=npu-operator

# [선택] 배포 대상 네임스페이스 (없으면 자동 생성됨, 기본값: npu-operator)
NAMESPACE=npu-operator

# [선택] 차트 경로 또는 OCI 레퍼런스 (기본값: 이 스크립트 위치의 ./  )
# 로컬 차트: CHART=./
# OCI 차트:  CHART=oci://<your-registry>/charts/npu-operator
CHART=./

# [선택] 추가 helm 인수 (공백 구분, -f override 파일 등)
# 예: EXTRA_ARGS="-f values-airgap.yaml --set furiosa.enabled=false"
EXTRA_ARGS=
